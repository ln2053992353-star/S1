{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django: Run Server",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": ["runserver"],
            "django": true,
            "env": {
                "HF_ENDPOINT": "https://hf-mirror.com",
                "NO_PROXY": "ark.cn-beijing.volces.com,localhost,127.0.0.1",
                "DJANGO_SETTINGS_MODULE": "smart_search_project.settings"
            },
            "justMyCode": false
        },
        {
            "name": "Django: Debug Server",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": ["runserver", "--noreload"],
            "django": true,
            "env": {
                "HF_ENDPOINT": "https://hf-mirror.com",
                "NO_PROXY": "ark.cn-beijing.volces.com,localhost,127.0.0.1",
                "DJANGO_SETTINGS_MODULE": "smart_search_project.settings"
            },
            "justMyCode": false
        },
        {
            "name": "Django: Make Migrations",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": ["makemigrations"],
            "django": true,
            "env": {
                "DJANGO_SETTINGS_MODULE": "smart_search_project.settings"
            }
        },
        {
            "name": "Django: Migrate",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": ["migrate"],
            "django": true,
            "env": {
                "DJANGO_SETTINGS_MODULE": "smart_search_project.settings"
            }
        },
        {
            "name": "Django: Run Tests",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": ["test"],
            "django": true,
            "env": {
                "DJANGO_SETTINGS_MODULE": "smart_search_project.settings"
            }
        },
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}